{
    "name": "GitHub Light",
    "kind": "light",
    "levels": {
        "Trace": { "foreground": "#6E7781", "background": "#F6F8FA" },
        "Debug": { "foreground": "#0969DA", "background": "#DDF4FF" },
        "Info":  {},
        "Warn":  { "foreground": "#9A6700", "background": "#FFF8C5" },
        "Error": { "foreground": "#CF222E", "background": "#FFEBE9" },
        "Fatal": { "foreground": "#82071E", "background": "#FFCECB", "bold": true }
    },
    "table": {
        "background": "#FFFFFF",
        "alternateRowBackground": "#F6F8FA",
        "selectionBackground": "#0969DA",
        "selectionForeground": "#FFFFFF"
    },
    "anchorPalette": [
        "#CF222E",
        "#BC4C00",
        "#9A6700",
        "#1A7F37",
        "#118784",
        "#218BFF",
        "#8250DF",
        "#BF3989"
    ],
    "chrome": {
        "window": "#F6F8FA",
        "windowText": "#1F2328",
        "text": "#1F2328",
        "button": "#F6F8FA",
        "buttonText": "#1F2328",
        "placeholderText": "#6E7781",
        "toolTipBase": "#F6F8FA",
        "toolTipText": "#1F2328"
    },
    "app": {
        "qtStyle": "fusion"
    },
    "levelColumnOverride": {
        "headerIcon": ":/icons/gauge.svg",
        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#DDF4FF" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#FFEFC2" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#FFDFDA" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#FFCECB", "pillForeground": "#82071E" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
        }
    }
}
