{
    "name": "Material Light",
    "kind": "light",
    "levels": {
        "Trace": { "foreground": "#90A4AE", "background": "#F3F5F6" },
        "Debug": { "foreground": "#3A77B6", "background": "#EFF6FB" },
        "Info":  {},
        "Warn":  { "foreground": "#A56F00", "background": "#FCF6E6" },
        "Error": { "foreground": "#E53935", "background": "#FCEEF1" },
        "Fatal": { "foreground": "#B71C1C", "background": "#FBD9DC", "bold": true }
    },
    "levelsHighContrast": {
        "Warn":  { "foreground": "#C17E00", "background": "#FFF8E1" },
        "Error": { "foreground": "#E53935", "background": "#FFEBEE" },
        "Fatal": { "foreground": "#B71C1C", "background": "#FFCDD2", "bold": true }
    },
    "table": {
        "background": "#FAFAFA",
        "alternateRowBackground": "#ECEFF1",
        "selectionBackground": "#B2DFDB",
        "selectionForeground": "#263238"
    },
    "anchorPalette": [
        "#C62828",
        "#E64A19",
        "#B28704",
        "#2E7D32",
        "#00838F",
        "#1565C0",
        "#6A1B9A",
        "#AD1457"
    ],
    "chrome": {
        "window": "#FAFAFA",
        "windowText": "#37474F",
        "text": "#37474F",
        "button": "#ECEFF1",
        "buttonText": "#37474F",
        "placeholderText": "#90A4AE",
        "toolTipBase": "#ECEFF1",
        "toolTipText": "#37474F"
    },
    "app": {
        "qtStyle": "fusion"
    },
    "levelColumnOverride": {
        "headerIcon": ":/icons/gauge.svg",
        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#E3F2FD" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#FFECB3" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#FFCDD2" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#EF9A9A", "pillForeground": "#B71C1C" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
        }
    }
}
