        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#3E5470" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#665520" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#6E2B33" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#7A2C36", "pillForeground": "#ECEFF4" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
