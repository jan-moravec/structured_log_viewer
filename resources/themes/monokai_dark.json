{
    "name": "Monokai Dark",
    "kind": "dark",
    "levels": {
        "Trace": { "foreground": "#75715E", "background": "#2D2E27" },
        "Debug": { "foreground": "#66D9EF", "background": "#1E2A2D" },
        "Info":  {},
        "Warn":  { "foreground": "#FD971F", "background": "#3A2F1A" },
        "Error": { "foreground": "#F92672", "background": "#3A1A22" },
        "Fatal": { "foreground": "#FFAAC1", "background": "#5C1B30", "bold": true }
    },
    "table": {
        "background": "#272822",
        "alternateRowBackground": "#2D2E27",
        "selectionBackground": "#49483E",
        "selectionForeground": "#F8F8F2"
    },
    "anchorPalette": [
        "#A6172E",
        "#C46B1A",
        "#A98F1B",
        "#2E7D32",
        "#1F8A85",
        "#1565C0",
        "#7C3AED",
        "#C2185B"
    ],
    "chrome": {
        "window": "#272822",
        "windowText": "#F8F8F2",
        "text": "#F8F8F2",
        "button": "#3E3D32",
        "buttonText": "#F8F8F2",
        "placeholderText": "#75715E",
        "toolTipBase": "#3E3D32",
        "toolTipText": "#F8F8F2"
    },
    "app": {
        "qtStyle": "fusion"
    },
    "levelColumnOverride": {
        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#234A55" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#5C4A12" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#5C2231" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#5C1B30", "pillForeground": "#FFAAC1" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
        }
    }
}
