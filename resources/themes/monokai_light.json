{
    "name": "Monokai Light",
    "kind": "light",
    "levels": {
        "Trace": { "foreground": "#7C7361", "background": "#F0E9C9" },
        "Debug": { "foreground": "#1C8CA8", "background": "#D5EBF0" },
        "Info":  {},
        "Warn":  { "foreground": "#CC7A0A", "background": "#FBE6CA" },
        "Error": { "foreground": "#E14775", "background": "#F8D5DD" },
        "Fatal": { "foreground": "#9E1F4E", "background": "#F2A0B8", "bold": true }
    },
    "table": {
        "background": "#FAF4CE",
        "alternateRowBackground": "#F0E9C9",
        "selectionBackground": "#E6DCBE",
        "selectionForeground": "#2C232E"
    },
    "anchorPalette": [
        "#C0282C",
        "#D55E0A",
        "#A57F0E",
        "#1E8449",
        "#138D8A",
        "#1E69B5",
        "#7E36CC",
        "#B22765"
    ],
    "chrome": {
        "window": "#FAF4CE",
        "windowText": "#2C232E",
        "text": "#2C232E",
        "button": "#F0E9C9",
        "buttonText": "#2C232E",
        "placeholderText": "#7C7361",
        "toolTipBase": "#F0E9C9",
        "toolTipText": "#2C232E"
    },
    "app": {
        "qtStyle": "fusion"
    },
    "levelColumnOverride": {
        "headerIcon": ":/icons/gauge.svg",
        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#D5EBF0" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#F7D9A1" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#F0BAC4" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#F2A0B8", "pillForeground": "#9E1F4E" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
        }
    }
}
