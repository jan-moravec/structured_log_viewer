{
    "name": "Material Dark",
    "kind": "dark",
    "levels": {
        "Trace": { "foreground": "#546E7A", "background": "#1F272A" },
        "Debug": { "foreground": "#82AAFF", "background": "#1A2332" },
        "Info":  {},
        "Warn":  { "foreground": "#FFCB6B", "background": "#332A18" },
        "Error": { "foreground": "#F07178", "background": "#3A1F22" },
        "Fatal": { "foreground": "#FFCDD2", "background": "#5C1B25", "bold": true }
    },
    "table": {
        "background": "#263238",
        "alternateRowBackground": "#2A373D",
        "selectionBackground": "#425B67",
        "selectionForeground": "#EEFFFF"
    },
    "anchorPalette": [
        "#C62828",
        "#D84315",
        "#A6760B",
        "#2E7D32",
        "#00838F",
        "#1565C0",
        "#6A1B9A",
        "#AD1457"
    ],
    "chrome": {
        "window": "#263238",
        "windowText": "#EEFFFF",
        "text": "#EEFFFF",
        "button": "#314549",
        "buttonText": "#EEFFFF",
        "placeholderText": "#546E7A",
        "toolTipBase": "#314549",
        "toolTipText": "#EEFFFF"
    },
    "app": {
        "qtStyle": "fusion"
    },
    "levelColumnOverride": {
        "headerIcon": ":/icons/gauge.svg",
        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#1A2E55" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#5C4015" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#4A1D1D" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#5C1B25", "pillForeground": "#FFCDD2" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
        }
