{
    "name": "Dark",
    "kind": "dark",
    "levels": {
        "Trace": { "foreground": "#64748B", "background": "#1F2228" },
        "Debug": { "foreground": "#94A3B8", "background": "#20252E" },
        "Info":  {},
        "Warn":  { "foreground": "#FCD34D", "background": "#2A2418" },
        "Error": { "foreground": "#FCA5A5", "background": "#4C1D1D" },
        "Fatal": { "foreground": "#FECACA", "background": "#7F1D1D", "bold": true }
    },
    "table": {
        "background": "#222222",
        "alternateRowBackground": "#2A2A2A",
        "selectionBackground": "#3949AB",
        "selectionForeground": "#FFFFFF"
    },
    "anchorPalette": [
        "#B91C1C",
        "#C2410C",
        "#A16207",
        "#15803D",
        "#0F766E",
        "#0369A1",
        "#7E22CE",
        "#BE185D"
    ],
    "chrome": {
        "window": "#2A2A2A",
        "windowText": "#E5E7EB",
        "text": "#E5E7EB",
        "button": "#374151",
        "buttonText": "#E5E7EB",
        "placeholderText": "#9CA3AF",
        "toolTipBase": "#2A2A2A",
        "toolTipText": "#E5E7EB"
    },
    "app": {
        "qtStyle": "fusion"
    },
    "levelColumnOverride": {
        "headerIcon": ":/icons/gauge.svg",
        "levels": {
            "Trace":   { "icon": ":/icons/level-trace.svg" },
            "Debug":   { "icon": ":/icons/level-debug.svg" },
            "Info":    { "icon": ":/icons/level-info.svg",    "pillBackground": "#1E3A5F" },
            "Warn":    { "icon": ":/icons/level-warn.svg",    "pillBackground": "#7C5A12" },
            "Error":   { "icon": ":/icons/level-error.svg",   "pillBackground": "#7F1D1D" },
            "Fatal":   { "icon": ":/icons/level-fatal.svg",   "pillBackground": "#7F1D1D", "pillForeground": "#FECACA" },
            "Unknown": { "icon": ":/icons/level-unknown.svg" }
        }
    }
}
