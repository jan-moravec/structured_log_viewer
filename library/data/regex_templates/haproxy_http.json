{
    "name": "HAProxy HTTP",
    "pattern": "^(?<timestamp>[A-Z][a-z]{2}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2})\\s+(?<hostname>\\S+)\\s+haproxy\\[(?<pid>\\d+)\\]:\\s+(?<clientip>\\S+):(?<clientport>\\d+)\\s+\\[(?<accept_date>[^\\]]+)\\]\\s+(?<frontend_name>\\S+)\\s+(?<backend_name>\\S+)/(?<server_name>\\S+)\\s+(?<tq>-?\\d+)/(?<tw>-?\\d+)/(?<tc>-?\\d+)/(?<tr>-?\\d+)/(?<tt>\\+?\\d+)\\s+(?<status_code>\\d{3})\\s+(?<bytes_read>\\d+)\\s+(?<captured_request_cookie>\\S+)\\s+(?<captured_response_cookie>\\S+)\\s+(?<termination_state>\\S+)\\s+(?<actconn>\\d+)/(?<feconn>\\d+)/(?<beconn>\\d+)/(?<srvconn>\\d+)/(?<retries>\\+?\\d+)\\s+(?<srv_queue>\\d+)/(?<backend_queue>\\d+)\\s+\\{(?<captured_request_headers>[^}]*)\\}\\s+\\{(?<captured_response_headers>[^}]*)\\}\\s+\"(?<verb>\\S+)\\s+(?<request>\\S+)(?:\\s+HTTP/(?<httpversion>\\S+))?\"$",
    "sampleLines": [
        "May 17 12:34:56 lb01 haproxy[1234]: 10.0.0.1:54321 [17/May/2024:12:34:56.789] fe_main be_api/srv01 0/0/1/15/16 200 532 - - ---- 12/3/0/0/0 0/0 {example.com|curl/8.5.0} {nginx/1.25.3|application/json} \"GET /api/v1/health HTTP/1.1\"",
        "May 17 12:35:01 lb01 haproxy[1234]: 192.168.1.1:33442 [17/May/2024:12:35:01.001] fe_main be_api/srv02 0/0/0/5/+5 503 256 - - sH-- 13/4/1/0/+1 0/0 {} {} \"POST /v1/orders HTTP/2.0\""
    ],
    "autoDetect": true,
    "priority": 10,
    "description": "Adapted from lnav src/formats/haproxy_log.json (BSD-2-Clause). The HTTP format string is described in HAProxy's documentation (Section 8.2.3 'HTTP log format'); it sits inside a syslog frame so the timestamp / hostname / 'haproxy[pid]:' prefix matches RFC3164."
}
