{
    "name": "Syslog (RFC5424)",
    "pattern": "^<(?<priority>\\d+)>(?<version>\\d+)\\s+(?<timestamp>\\S+)\\s+(?<hostname>\\S+)\\s+(?<appname>\\S+)\\s+(?<procid>\\S+)\\s+(?<msgid>\\S+)\\s+(?<structured>\\[(?:[^\\]\"]|\"(?:\\\\.|[^\"])*\")*\\]|-)\\s*(?<message>.*)$",
    "sampleLines": [
        "<46>1 2017-04-27T07:50:47.381967+02:00 logserver rsyslogd - - [origin software=\"rsyslogd\"] start",
        "<30>1 2017-04-27T07:59:12+02:00 host dhclient - - - DHCPREQUEST on eth0",
        "<78>1 2017-04-27T08:09:01+02:00 host CRON 1472 - - (root) CMD (test)"
    ],
    "autoDetect": true,
    "priority": 10,
    "description": "Adapted from lnav src/formats/syslog_log.json rfc5424 pattern (BSD-2-Clause)."
}
