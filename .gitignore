# Build
/build/

# Ad-hoc test runner output captured at the workspace root (e.g.
# `apptest.exe > apptest_o.txt`). Build artifacts already live under
# `/build/`; this catches stray captures left over from local runs.
/apptest*.log
/apptest*.txt
/test_*.txt
/test_*.log

# Third-party AI dev tasks helper (cloned alongside, not part of the project)
/ai-dev-tasks-main/
# Benchmark scratch dirs (one per investigation, freely named).
# Pattern keeps `.bench-results/`, `.bench-results-prefix/`, etc. out.
.bench-results*/

# Local working plans / scratch design docs that should stay out of the repo.
/doc/gui_modernization.md
